<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Opencart App Test Regression Suite" verbose="3" thread-count="2" parallel="tests">


	<listeners>
		<listener class-name="com.avenstack.chaintest.plugins.ChainTestListener"/>
		<listener class-name="com.qa.opencart.listeners.TestAllureListener"/>
		<listener class-name="com.qa.opencart.listeners.AnnotationTransformer"/>
	</listeners>

	<test name="Login Page Test_chrome">
		<parameter name="browser" value="chrome"/>
		
		<classes>
			<class name="pom.qa.opencart.tests.LoginPageTest"/>
		</classes>
	</test>
	<test name="Login Page Test_firefox">
		<parameter name="browser" value="firefox"/>
		<classes>
			<class name="pom.qa.opencart.tests.LoginPageTest"/>
		</classes>
	</test>
	<test name="Login Page Test_edge">
		<parameter name="browser" value="edge"/>
		<classes>
			<class name="pom.qa.opencart.tests.LoginPageTest"/>
		</classes>
	</test>


	<test name="Accounts Page Test_firefox">
		<parameter name="browser" value="firefox"/>
		<classes>
			<class name="pom.qa.opencart.tests.AccountsPageTest" />
		</classes>
	</test>
	<test name="Accounts Page Test_chrome">
		<parameter name="browser" value="chrome"/>
		<classes>
			<class name="pom.qa.opencart.tests.AccountsPageTest" />
		</classes>
	</test>
	<test name="Accounts Page Test_edge">
		<parameter name="browser" value="edge"/>
		<classes>
			<class name="pom.qa.opencart.tests.AccountsPageTest" />
		</classes>
	</test>

	<test name="Search Test_safari">
		<parameter name="browser" value="safari"/>
		<classes>
			<class name="pom.qa.opencart.tests.SearchTest" />
		</classes>
	</test>
	<test name="Search Test_edge">
		<parameter name="browser" value="edge"/>
		<classes>
			<class name="pom.qa.opencart.tests.SearchTest" />
		</classes>
	</test>
	<test name="Search Test_chrome">
		<parameter name="browser" value="chrome"/>
		<classes>
			<class name="pom.qa.opencart.tests.SearchTest" />
		</classes>
	</test>


	<test name="ProductInfo Page Test">
		<parameter name="browser" value="edge"/>
		
		<classes>
			<class name="pom.qa.opencart.tests.ProductInfoPageTest" />
		</classes>
	</test>

	<test name="Register Page Test">
		<parameter name="browser" value="chrome"/>

		<classes>
			<class name="pom.qa.opencart.tests.RegisterPageTest" />
		</classes>
	</test>


</suite>	